        <item>
            <title>1.4.2</title>
            <pubDate>Tue, 21 Jul 2026 21:50:16 -0700</pubDate>
            <sparkle:version>9</sparkle:version>
            <sparkle:shortVersionString>1.4.2</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description><![CDATA[<h2>1.4.2</h2>
<p>Otto now answers noticeably faster. Simple requests no longer wait on deep reasoning they don't need, and the app is ready for your next message the moment a reply arrives.</p>
]]></description>
