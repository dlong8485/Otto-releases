            <sparkle:version>3</sparkle:version>
            <sparkle:shortVersionString>1.1.1</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description><![CDATA[<h2>1.1.1</h2>
<p>Bills now read correctly for past months — months before you started tracking a bill come to zero, and paying a new month no longer makes an older paid month look unpaid.</p>
]]></description>
