            <sparkle:shortVersionString>1.5.5</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <sparkle:hardwareRequirements>arm64</sparkle:hardwareRequirements>
            <description><![CDATA[<h2>1.5.5</h2>
<p>Otto stays fast after you've been away — it keeps its brain warmed up all day (and re-warms when your Mac wakes), and very long conversations no longer slow every answer down.</p>
]]></description>
